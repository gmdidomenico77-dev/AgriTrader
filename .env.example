# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real credentials.

# Backend URL — set this to your Northflank service URL after deploying.
# Include /api at the end, no trailing slash.
# Example: EXPO_PUBLIC_API_URL=https://agritrader-backend-xxxx.northflank.app/api
EXPO_PUBLIC_API_URL=
